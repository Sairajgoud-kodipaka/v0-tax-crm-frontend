# --- Safe to expose (NEXT_* is bundled into the client; Supabase anon key relies on RLS) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-or-publishable-key

# --- Server-only: never use NEXT_PUBLIC_ prefix; never import in client components ---
# Required for server actions that bypass RLS (e.g. client-created tickets). Set in Vercel env, not in repo.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (invitation links, redirects). On Vercel use https://your-app.vercel.app or your domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Development-only fallback for invoice payment without Stripe.
ALLOW_MVP_MANUAL_PAYMENT=false
